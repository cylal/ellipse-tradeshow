# ─── API Backend ─────────────────────────────────────────────────────────────
# URL de l'Azure Function App (backend CRM)
API_BASE_URL=https://ellipse-crm-api.azurewebsites.net/api

# ─── Azure AD / MSAL (Authentification) ─────────────────────────────────────
# Client ID de l'app registration "Ellipse TradeShow" dans Azure Entra ID
MSAL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Tenant ID Azure AD d'Ellipse
MSAL_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Redirect URI pour MSAL (doit correspondre à l'app registration)
MSAL_REDIRECT_URI=msauth.la.ellipse.tradeshow://auth

# ─── EAS (Expo Application Services) ────────────────────────────────────────
# ID du projet EAS (obtenu après `eas init`)
EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Apple Developer (TestFlight) ───────────────────────────────────────────
# Apple Team ID (visible dans developer.apple.com > Membership)
APPLE_TEAM_ID=XXXXXXXXXX

# App Store Connect App ID (numérique, visible dans App Store Connect)
ASC_APP_ID=1234567890
