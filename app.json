{
  "expo": {
    "name": "Ellipse Field Activity",
    "slug": "ellipse-tradeshow",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "la.ellipse.tradeshow",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C41E2A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "la.ellipse.tradeshow",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to capture badges, business cards, and portrait photos.",
        "NSMicrophoneUsageDescription": "Microphone is used to record conversations during trade show encounters.",
        "NSPhotoLibraryUsageDescription": "Photo library access is used to import badge and business card photos.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Face ID allows you to sign in quickly without re-entering your password."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C41E2A"
      },
      "package": "la.ellipse.tradeshow",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      ["./plugins/withKotlinVersion", "1.9.25"],
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "pickFirst": ["**/libreactnative.so"]
            }
          }
        }
      ],
      "expo-router",
      "expo-camera",
      "expo-av",
      "expo-image-picker",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#C41E2A",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "26dffcf8-3854-4d95-923b-28983f8f9cc9"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "cylal"
  }
}